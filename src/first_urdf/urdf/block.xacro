<?xml version="1.0"?>
<robot name="simple_block">

    <joint name="wheel1_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel1"/>
        <axis xyz="0 0 1"/>
        <origin xyz="-0.575 0.3 -0.4" rpy="1.5708 0 1.5708"/>
    </joint>

    <joint name="wheel2_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel2"/>
        <axis xyz="0 0 1"/>
        <origin xyz="0.575 0.3 -0.4" rpy="1.5708 0 1.5708"/>
    </joint>

    <joint name="wheel3_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel3"/>
        <axis xyz="0 0 1"/>
        <origin xyz="-0.575 -0.3 -0.4" rpy="1.5708 0 1.5708"/>
    </joint>

    <joint name="wheel4_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel4"/>
        <axis xyz="0 0 1"/>
        <origin xyz="0.575 -0.3 -0.4" rpy="1.5708 0 1.5708"/>
    </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="1.0 1.0 1.0"/>
            </geometry>
            <material name="blue">
                <color rgba="0.2 0.4 0.8 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <box size="1.0 1.0 1.0"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="3.5"/>
            <inertia ixx="0.583" ixy="0.0" ixz="0.0" iyy="0.583" iyz="0.0" izz="0.583"/>
        </inertial>
    </link>

    <link name="wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.8"/>
            <inertia ixx="0.0095" ixy="0.0" ixz="0.0" iyy="0.0095" iyz="0.0" izz="0.016"/>
        </inertial>
    </link>
    <link name="wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.8"/>
            <inertia ixx="0.0095" ixy="0.0" ixz="0.0" iyy="0.0095" iyz="0.0" izz="0.016"/>
        </inertial>
    </link>
    <link name="wheel3">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.8"/>
            <inertia ixx="0.0095" ixy="0.0" ixz="0.0" iyy="0.0095" iyz="0.0" izz="0.016"/>
        </inertial>
    </link>
    <link name="wheel4">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.8"/>
            <inertia ixx="0.0095" ixy="0.0" ixz="0.0" iyy="0.0095" iyz="0.0" izz="0.016"/>
        </inertial>
    </link>

    <ros2_control name="first_urdf_control" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>
        <joint name="wheel1_to_base">
            <command_interface name="velocity">
                <param name="min">-10</param>
                <param name="max">10</param>
            </command_interface>
            <state_interface name="velocity"/>
            <state_interface name="position"/>
        </joint>
        <joint name="wheel2_to_base">
            <command_interface name="velocity">
                <param name="min">-10</param>
                <param name="max">10</param>
            </command_interface>
            <state_interface name="velocity"/>
            <state_interface name="position"/>
        </joint>
        <joint name="wheel3_to_base">
            <command_interface name="velocity">
                <param name="min">-10</param>
                <param name="max">10</param>
            </command_interface>
            <state_interface name="velocity"/>
            <state_interface name="position"/>
        </joint>
        <joint name="wheel4_to_base">
            <command_interface name="velocity">
                <param name="min">-10</param>
                <param name="max">10</param>
            </command_interface>
            <state_interface name="velocity"/>
            <state_interface name="position"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so"> 
            <parameters>$(find first_urdf)/config/controller.yaml</parameters> 
        </plugin>
    </gazebo>

    <gazebo reference="wheel1">
        <mu1>0.8</mu1>
        <mu2>0.5</mu2>
    </gazebo>

    <gazebo reference="wheel4">
        <mu1>0.8</mu1>
        <mu2>0.5</mu2>
    </gazebo>

   <gazebo reference="wheel3">
        <mu1>0.8</mu1>
        <mu2>0.5</mu2>
    </gazebo>

    <gazebo reference="wheel2">
        <mu1>0.8</mu1>
        <mu2>0.5</mu2>
    </gazebo>

    <gazebo reference="base_link">
        <material>Gazebo/Blue</material>
    </gazebo>

    <gazebo reference="wheel1">
        <material>Gazebo/Red</material>
    </gazebo>

    <gazebo reference="wheel2">
        <material>Gazebo/Red</material>
    </gazebo>

    <gazebo reference="wheel3">
        <material>Gazebo/Red</material>
    </gazebo>

    <gazebo reference="wheel4">
        <material>Gazebo/Red</material>
    </gazebo>

</robot>