<?xml version="1.0"?>
<robot name="simple_block">

    <joint name="wheel1_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel1"/>
        <axis xyz="0 0 1"/>
        <origin xyz="-0.5 0.5 -0.4" rpy="1.5708 0 0"/>
    </joint>

    <joint name="wheel2_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel2"/>
        <axis xyz="0 0 1"/>
        <origin xyz="0.5 0.5 -0.4" rpy="1.5708 0 0"/>
    </joint>

    <joint name="wheel3_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel3"/>
        <axis xyz="0 0 1"/>
        <origin xyz="-0.5 -0.5 -0.4" rpy="1.5708 0 0"/>
    </joint>

    <joint name="wheel4_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel4"/>
        <axis xyz="0 0 1"/>
        <origin xyz="0.5 -0.5 -0.4" rpy="1.5708 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="1.0 1.0 1.0"/>
            </geometry>
            <material name="blue">
                <color rgba="0.2 0.4 0.8 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <box size="1.0 1.0 1.0"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="3.5"/>
            <inertia ixx="0.583" ixy="0.0" ixz="0.0" iyy="0.583" iyz="0.0" izz="0.583"/>
        </inertial>
    </link>

    <link name="wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.8"/>
            <inertia ixx="0.0095" ixy="0.0" ixz="0.0" iyy="0.0095" iyz="0.0" izz="0.016"/>
        </inertial>
    </link>
    <link name="wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.8"/>
            <inertia ixx="0.0095" ixy="0.0" ixz="0.0" iyy="0.0095" iyz="0.0" izz="0.016"/>
        </inertial>
    </link>
    <link name="wheel3">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.8"/>
            <inertia ixx="0.0095" ixy="0.0" ixz="0.0" iyy="0.0095" iyz="0.0" izz="0.016"/>
        </inertial>
    </link>
    <link name="wheel4">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.8"/>
            <inertia ixx="0.0095" ixy="0.0" ixz="0.0" iyy="0.0095" iyz="0.0" izz="0.016"/>
        </inertial>
    </link>

    <gazebo>
        <plugin name="gazebo_ros_planar_move" filename="libgazebo_ros_planar_move.so">
            <ros>
                <!-- Overrides the default topic if you want, defaults to /cmd_vel -->
                <argument>~/cmd_vel:=cmd_vel</argument>
                <argument>~/odom:=odom</argument>
             </ros>
            <update_rate>50</update_rate>
            <publish_rate>50</publish_rate>

            <!-- Must match your robot's root link -->
            <robot_base_frame>base_link</robot_base_frame>

            <!-- Set to true if you want the plugin to handle odometry publishing -->
            <publish_odom>true</publish_odom>
            <publish_odom_tf>true</publish_odom_tf>
            
            <covariance_x>0.0001</covariance_x>
            <covariance_y>0.0001</covariance_y>
            <covariance_yaw>0.01</covariance_yaw>
        </plugin>
    </gazebo>

    <gazebo reference="base_link">
        <material>Gazebo/Blue</material>
    </gazebo>

    <gazebo reference="wheel1">
        <material>Gazebo/Red</material>
    </gazebo>

    <gazebo reference="wheel2">
        <material>Gazebo/Red</material>
    </gazebo>

    <gazebo reference="wheel3">
        <material>Gazebo/Red</material>
    </gazebo>

    <gazebo reference="wheel4">
        <material>Gazebo/Red</material>
    </gazebo>

</robot>