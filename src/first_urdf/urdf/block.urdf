<?xml version="1.0"?>
<robot name="simple_block">

    <link name="world"/>

    <joint name="world_to_base" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <joint name="wheel1_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel1"/>
        <axis xyz="0 0 1"/>
        <origin xyz="-0.575 0.3 -0.4" rpy="1.5708 0 1.5708"/>
    </joint>

    <joint name="wheel2_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel2"/>
        <axis xyz="0 0 1"/>
        <origin xyz="0.575 0.3 -0.4" rpy="1.5708 0 1.5708"/>
    </joint>

    <joint name="wheel3_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel3"/>
        <axis xyz="0 0 1"/>
        <origin xyz="-0.575 -0.3 -0.4" rpy="1.5708 0 1.5708"/>
    </joint>

    <joint name="wheel4_to_base" type="continuous">
        <parent link="base_link"/>
        <child link="wheel4"/>
        <axis xyz="0 0 1"/>
        <origin xyz="0.575 -0.3 -0.4" rpy="1.5708 0 1.5708"/>
    </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="1.0 1.0 1.0"/>
            </geometry>
            <material name="blue">
                <color rgba="0.2 0.4 0.8 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <box size="1.0 1.0 1.0"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.4"/>
            <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.0"/>
        </inertial>
    </link>

    <link name="wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
        </inertial>
    </link>
    <link name="wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
        </inertial>
    </link>
    <link name="wheel3">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
        </inertial>
    </link>
    <link name="wheel4">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
        </inertial>
    </link>

</robot>